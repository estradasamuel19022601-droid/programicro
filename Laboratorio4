/****************************************/
// Encabezado (Libraries)
//Frecuencia
#define F_CPU 16000000UL

//Librerias 
#include <avr/io.h>
#include <util/delay.h>

/****************************************/
// Function prototypes
uint8_t contador = 0;

uint8_t debounce(volatile uint8_t *puerto, uint8_t bit);
void init(void);
/****************************************/
// Main Function
int main(void)
{
	init();
	
	while (1)
	{
		//boton incremento 
		if(debounce(&PINC, PC4)){
			contador++;
			while(!(PINC &(1<<PC4)));
		}
		if(debounce(&PINC, PC3)){
			contador--;
			while(!(PINC & (1<<PC3)));
		}
		
		//Para mostrar las leds se usara el puerto B y C
		//bits de 0-5 para los pines del puerto B
		PORTB = (PORTB & 0xC0)|(contador & 0x3F);
		
		//bits 6-7 para pines del puerto C
		PORTC = (PORTC & 0xFC) | ((contador >> 6)& 0x03);
	}
		
}
/****************************************/
// NON-Interrupt subroutines
void init(void){
	//Activar los bits 0-5 como salidas para leds del puerto B (PB0-PB5)
	DDRB |= 0x3F;
	
	//Activarf los bits 6-7 como salidas para el puerto C (PC0 y PC1)
	DDRC |= (1<<PC0)|(1<<PC1); 
	
	//Activar PC3 y PC4 como entrada para los botones y PC5 para leer el potenciometro
	DDRC &= ~((1<<PC4)|(1<<PC3)|(1<<PC5));
	
	//activar pull-up en los pines de los botones
	PORTC |= (1<<PC3)|(1<<PC4);
	
}

uint8_t debounce(volatile uint8_t *puerto, uint8_t bit){
	if (!(*puerto & (1<<bit)))
	{
		_delay_ms(20);
		if (!(*puerto & (1<<bit)))
		{
			return 1;
		}
	}
	return 0;
}
